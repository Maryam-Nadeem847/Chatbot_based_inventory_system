<!DOCTYPE html>
<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--font-sans);background:var(--color-background-tertiary);color:var(--color-text-primary)}
a{text-decoration:none;color:inherit}
.teal{color:#0F6E56}

nav{background:var(--color-background-primary);border-bottom:0.5px solid var(--color-border-tertiary);padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:60px;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px;font-size:17px;font-weight:500}
.logo-icon{width:32px;height:32px;background:#0F6E56;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.nav-links{display:flex;align-items:center;gap:1.25rem}
.nav-links .nav-text{font-size:13px;color:var(--color-text-secondary)}
.hamburger{display:none;background:none;border:0.5px solid var(--color-border-secondary);border-radius:6px;padding:6px 8px;cursor:pointer;color:var(--color-text-primary)}
.mobile-menu{display:none;flex-direction:column;gap:0;background:var(--color-background-primary);border-bottom:0.5px solid var(--color-border-tertiary);padding:0.5rem 1.5rem 1rem}
.mobile-menu.open{display:flex}
.mobile-menu a{font-size:14px;color:var(--color-text-secondary);padding:10px 0;border-bottom:0.5px solid var(--color-border-tertiary)}
.mobile-menu a:last-child{border-bottom:none}
.mobile-menu .mob-btns{display:flex;gap:8px;padding-top:10px}

.btn-primary,.btn-outline,.btn-white,.btn-ghost{display:inline-flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;font-family:var(--font-sans);font-size:14px;border-radius:var(--border-radius-md);transition:background .15s ease}
.btn-primary{background:#0F6E56;color:#fff;border:none;padding:8px 18px}
.btn-primary:hover{background:#085041}
.btn-outline{background:transparent;border:0.5px solid var(--color-border-secondary);padding:8px 18px;color:var(--color-text-primary)}
.btn-outline:hover{background:var(--color-background-secondary)}
.btn-large{padding:12px 24px;font-size:15px}

.hero{padding:3.5rem 1.5rem 2.5rem;text-align:center;max-width:760px;margin:0 auto}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:#E1F5EE;color:#0F6E56;font-size:12px;padding:4px 12px;border-radius:20px;margin-bottom:1.25rem}
.badge-dot{animation:pulseDot 1.8s ease-in-out infinite}
.hero h1{font-size:36px;font-weight:500;line-height:1.2;margin-bottom:1rem;letter-spacing:-0.3px}
.hero h1 span{color:#0F6E56}
.hero p{font-size:16px;color:var(--color-text-secondary);line-height:1.7;max-width:520px;margin:0 auto 1.75rem}
.hero-btns{display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap}

.mic-demo{margin:2.5rem auto 0;max-width:400px;background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1.25rem}
.mic-label{font-size:12px;color:var(--color-text-secondary);margin-bottom:0.75rem;text-align:center;display:flex;align-items:center;justify-content:center;gap:6px}
.rec-dot{width:6px;height:6px;border-radius:50%;background:#0F6E56;animation:pulseDot 1.6s ease-in-out infinite;display:inline-block}
@keyframes pulseDot{0%,100%{opacity:.35;transform:scale(.8)}50%{opacity:1;transform:scale(1.2)}}
.waveform{display:flex;align-items:center;justify-content:center;gap:3px;height:44px;margin-bottom:0.75rem}
.waveform .bar{width:4px;background:#0F6E56;border-radius:2px;animation:wave 1.2s ease-in-out infinite}
.waveform .bar:nth-child(1){animation-delay:0s}.waveform .bar:nth-child(2){animation-delay:.1s}.waveform .bar:nth-child(3){animation-delay:.2s}.waveform .bar:nth-child(4){animation-delay:.3s}.waveform .bar:nth-child(5){animation-delay:.4s}.waveform .bar:nth-child(6){animation-delay:.5s}.waveform .bar:nth-child(7){animation-delay:.4s}.waveform .bar:nth-child(8){animation-delay:.3s}.waveform .bar:nth-child(9){animation-delay:.2s}.waveform .bar:nth-child(10){animation-delay:.1s}.waveform .bar:nth-child(11){animation-delay:0s}
@keyframes wave{0%,100%{height:8px}50%{height:34px}}
.voice-text{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:9px 12px;font-size:13px;color:var(--color-text-secondary);text-align:center}
.voice-response{margin-top:7px;background:#E1F5EE;border-radius:var(--border-radius-md);padding:9px 12px;font-size:13px;color:#085041;text-align:center}

.lang-strip{background:var(--color-background-secondary);border-top:0.5px solid var(--color-border-tertiary);border-bottom:0.5px solid var(--color-border-tertiary);padding:1rem 1.5rem;text-align:center}
.lang-pills{display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap;margin-top:.5rem}
.pill{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:20px;padding:4px 12px;font-size:12px;color:var(--color-text-secondary)}

.section{padding:3rem 1.5rem;max-width:960px;margin:0 auto}
.section-label{font-size:12px;color:#0F6E56;font-weight:500;text-transform:uppercase;letter-spacing:1px;margin-bottom:.6rem}
.section h2{font-size:26px;font-weight:500;margin-bottom:.6rem}
.section .sub{font-size:14px;color:var(--color-text-secondary);line-height:1.7;max-width:500px;margin-bottom:2rem}

.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
.feature-card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1.1rem}
.feature-icon{width:36px;height:36px;border-radius:var(--border-radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:.85rem;font-size:17px}
.fi-teal{background:#E1F5EE;color:#0F6E56}
.fi-amber{background:#FAEEDA;color:#BA7517}
.fi-blue{background:#E6F1FB;color:#185FA5}
.fi-coral{background:#FAECE7;color:#993C1D}
.feature-card h3{font-size:14px;font-weight:500;margin-bottom:.35rem}
.feature-card p{font-size:13px;color:var(--color-text-secondary);line-height:1.6}

.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;margin:2.5rem 0}
.stat-card{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:.85rem;text-align:center}
.stat-card .num{font-size:26px;font-weight:500;color:#0F6E56}
.stat-card .lbl{font-size:12px;color:var(--color-text-secondary);margin-top:2px}

.how-it-works{background:var(--color-background-primary);border-top:0.5px solid var(--color-border-tertiary);border-bottom:0.5px solid var(--color-border-tertiary);padding:3rem 1.5rem}
.how-inner{max-width:960px;margin:0 auto}
.steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1.5rem;margin-top:2rem}
.step{text-align:center}
.step-num{width:42px;height:42px;border-radius:50%;background:#0F6E56;color:#fff;font-size:15px;font-weight:500;display:flex;align-items:center;justify-content:center;margin:0 auto .85rem;box-shadow:0 0 0 6px #E1F5EE}
.step h3{font-size:14px;font-weight:500;margin-bottom:.35rem}
.step p{font-size:13px;color:var(--color-text-secondary);line-height:1.6}

.commands-section{padding:3rem 1.5rem;max-width:960px;margin:0 auto}
.commands-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:10px;margin-top:1.5rem}
.cmd-card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:.9rem 1.1rem;display:flex;align-items:flex-start;gap:10px}
.cmd-badge{font-size:11px;padding:3px 7px;border-radius:4px;font-weight:500;white-space:nowrap;flex-shrink:0;margin-top:1px}
.cb-add{background:#E1F5EE;color:#085041}
.cb-sale{background:#FAECE7;color:#993C1D}
.cb-check{background:#E6F1FB;color:#0C447C}
.cb-report{background:#FAEEDA;color:#854F0B}
.cb-buy{background:#EAF3DE;color:#3B6D11}
.cmd-text{font-size:13px;color:var(--color-text-secondary);line-height:1.5}
.cmd-text strong{color:var(--color-text-primary);font-weight:500;display:block;margin-bottom:2px;font-size:13px}

.cta-section{background:#0F6E56;padding:3.5rem 1.5rem;text-align:center}
.cta-section h2{font-size:26px;font-weight:500;color:#fff;margin-bottom:.65rem}
.cta-section p{font-size:14px;color:#9FE1CB;margin-bottom:1.75rem}
.cta-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.btn-white{background:#fff;color:#0F6E56;border:none;padding:11px 24px;font-weight:500}
.btn-ghost{background:transparent;border:1px solid rgba(255,255,255,0.4);color:#fff;padding:11px 24px}

footer{background:var(--color-background-primary);border-top:0.5px solid var(--color-border-tertiary);padding:2.5rem 1.5rem 1.5rem}
.footer-inner{max-width:960px;margin:0 auto}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:1.5rem;margin-bottom:2rem}
.footer-brand p{font-size:13px;color:var(--color-text-secondary);line-height:1.7;margin-top:.6rem;max-width:200px}
.footer-col h4{font-size:13px;font-weight:500;margin-bottom:.65rem}
.footer-col a{display:block;font-size:13px;color:var(--color-text-secondary);margin-bottom:.35rem;cursor:pointer}
.footer-bottom{border-top:0.5px solid var(--color-border-tertiary);padding-top:1rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem}
.footer-bottom p{font-size:12px;color:var(--color-text-secondary)}

@media (max-width: 640px) {
  .nav-links{display:none}
  .hamburger{display:flex;align-items:center;gap:4px;font-size:13px}

  .hero{padding:2.5rem 1.25rem 2rem}
  .hero h1{font-size:28px}
  .hero p{font-size:15px}
  .hero-btns{flex-direction:column;align-items:stretch}
  .hero-btns a,.hero-btns button{width:100%;justify-content:center}
  .btn-large{padding:13px 20px}

  .mic-demo{margin:2rem 0 0}

  .features-grid{grid-template-columns:1fr 1fr}
  .stats{grid-template-columns:1fr 1fr}
  .steps{grid-template-columns:1fr}

  .commands-grid{grid-template-columns:1fr}

  .footer-grid{grid-template-columns:1fr 1fr;gap:1.25rem}
  .footer-brand{grid-column:1/-1}
  .footer-brand p{max-width:100%}

  .cta-btns{flex-direction:column;align-items:stretch}
  .cta-btns a,.cta-btns button{width:100%;justify-content:center}

  .lang-pills .pill{font-size:11px;padding:3px 10px}
}

@media (max-width:360px){
  .hero h1{font-size:24px}
  .features-grid{grid-template-columns:1fr}
}

@media (prefers-reduced-motion:reduce){
  .badge-dot,.rec-dot,.waveform .bar{animation:none}
}
</style>

