<script>
window.addEventListener('scroll', () => {
  document.querySelector('nav').classList.toggle('scrolled', window.scrollY > 8);
});

const samples=[
  {cmd:'"50 kg chawal add karo, cost 120 rupay kilo"',res:'✓ "Rice" inventory mein add ho gaya — 50kg @ Rs.120/kg'},
  {cmd:'"aaj 5 kg doodh bika, 80 rupay litre"',res:'✓ 5 litre Milk sold record ho gaya. Bacha hua: 45 litre'},
  {cmd:'"sugar ka stock kitna hai"',res:'✓ Sugar: Total aaya 100kg, bika 30kg, bacha 70kg'},
  {cmd:'"is hafte ki report chahiye"',res:'✓ Week report: Rice Rs.750, Sugar Rs.2400, Milk Rs.480'},
  {cmd:'"konsa maal khatam ho raha hai"',res:'⚠ Salt: 3kg, Biscuit: 5 packets — restock zaroor karein'}
]
let si=0
setInterval(()=>{
  si=(si+1)%samples.length
  document.getElementById('voice-sample').textContent=samples[si].cmd
  document.getElementById('voice-reply').textContent=samples[si].res
},3000)
</script>