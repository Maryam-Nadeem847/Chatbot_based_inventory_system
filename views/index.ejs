<style>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:var(--font-sans);background:var(--color-background-tertiary);color:var(--color-text-primary)}
a{text-decoration:none;color:inherit}
.teal{color:#0F6E56}
.amber{color:#BA7517}

nav{background:var(--color-background-primary);border-bottom:0.5px solid var(--color-border-tertiary);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:60px;position:sticky;top:0;z-index:100;transition:box-shadow .2s ease}
nav.scrolled{box-shadow:0 2px 10px rgba(0,0,0,.05)}
.logo{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:500}
.logo-icon{width:34px;height:34px;background:#0F6E56;border-radius:8px;display:flex;align-items:center;justify-content:center}
.nav-links{display:flex;align-items:center;gap:1.5rem}
.nav-links a:not(.btn-outline):not(.btn-primary){font-size:14px;color:var(--color-text-secondary);transition:color .15s ease}
.nav-links a:not(.btn-outline):not(.btn-primary):hover{color:var(--color-text-primary)}

.btn-primary,.btn-outline,.btn-white,.btn-ghost{display:inline-flex;align-items:center;justify-content:center;gap:6px;cursor:pointer;font-family:var(--font-sans);font-size:14px;border-radius:var(--border-radius-md);transition:background .15s ease,transform .15s ease,box-shadow .15s ease}
.btn-primary{background:#0F6E56;color:#fff;border:none;padding:8px 20px;box-shadow:0 1px 2px rgba(15,110,86,.18)}
.btn-primary:hover{background:#085041;transform:translateY(-1px);box-shadow:0 6px 14px rgba(15,110,86,.28)}
.btn-outline{background:transparent;border:0.5px solid var(--color-border-secondary);padding:8px 20px;color:var(--color-text-primary)}
.btn-outline:hover{background:var(--color-background-secondary)}
.btn-primary:focus-visible,.btn-outline:focus-visible,.btn-white:focus-visible,.btn-ghost:focus-visible,.nav-links a:focus-visible,.footer-col a:focus-visible,.modal-switch a:focus-visible{outline:2px solid #0F6E56;outline-offset:2px;border-radius:4px}

.hero{padding:5rem 2rem 4rem;text-align:center;max-width:800px;margin:0 auto;position:relative}
.hero::before{content:"";position:absolute;top:-90px;left:50%;transform:translateX(-50%);width:520px;height:520px;background:radial-gradient(circle,rgba(15,110,86,.12) 0%,rgba(186,117,23,.07) 45%,transparent 70%);filter:blur(40px);pointer-events:none}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:#E1F5EE;color:#0F6E56;font-size:12px;padding:4px 12px;border-radius:20px;margin-bottom:1.5rem;position:relative}
.badge-dot{animation:pulseDot 1.8s ease-in-out infinite}
.hero h1{font-size:48px;font-weight:500;line-height:1.15;margin-bottom:1rem;letter-spacing:-0.5px;position:relative}
.hero h1 span{color:#0F6E56}
.hero p{font-size:17px;color:var(--color-text-secondary);line-height:1.7;max-width:560px;margin:0 auto 2rem;position:relative}
.hero-btns{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;position:relative}
.btn-large{padding:12px 28px;font-size:15px;border-radius:var(--border-radius-md)}

.mic-demo{margin:3rem auto;max-width:420px;background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1.5rem;position:relative;box-shadow:0 8px 28px rgba(15,110,86,.08)}
.mic-label{font-size:12px;color:var(--color-text-secondary);margin-bottom:1rem;text-align:center;display:flex;align-items:center;justify-content:center;gap:6px}
.rec-dot{width:6px;height:6px;border-radius:50%;background:#0F6E56;animation:pulseDot 1.6s ease-in-out infinite}
@keyframes pulseDot{0%,100%{opacity:.35;transform:scale(.8)}50%{opacity:1;transform:scale(1.2)}}
.waveform{display:flex;align-items:center;justify-content:center;gap:4px;height:48px;margin-bottom:1rem}
.waveform .bar{width:4px;background:#0F6E56;border-radius:2px;animation:wave 1.2s ease-in-out infinite}
.waveform .bar:nth-child(1){animation-delay:0s}
.waveform .bar:nth-child(2){animation-delay:.1s}
.waveform .bar:nth-child(3){animation-delay:.2s}
.waveform .bar:nth-child(4){animation-delay:.3s}
.waveform .bar:nth-child(5){animation-delay:.4s}
.waveform .bar:nth-child(6){animation-delay:.5s}
.waveform .bar:nth-child(7){animation-delay:.4s}
.waveform .bar:nth-child(8){animation-delay:.3s}
.waveform .bar:nth-child(9){animation-delay:.2s}
.waveform .bar:nth-child(10){animation-delay:.1s}
.waveform .bar:nth-child(11){animation-delay:0s}
@keyframes wave{0%,100%{height:8px}50%{height:36px}}
.voice-text{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:10px 14px;font-size:13px;color:var(--color-text-secondary);text-align:center;transition:opacity .2s ease}
.voice-response{margin-top:8px;background:#E1F5EE;border-radius:var(--border-radius-md);padding:10px 14px;font-size:13px;color:#085041;text-align:center;transition:opacity .2s ease}

.section{padding:4rem 2rem;max-width:1000px;margin:0 auto}
.section-label{font-size:12px;color:#0F6E56;font-weight:500;text-transform:uppercase;letter-spacing:1px;margin-bottom:.75rem}
.section h2{font-size:30px;font-weight:500;margin-bottom:.75rem}
.section .sub{font-size:15px;color:var(--color-text-secondary);line-height:1.7;max-width:520px;margin-bottom:2.5rem}

.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}
.feature-card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1.25rem;transition:transform .18s ease,box-shadow .18s ease}
.feature-card:hover{transform:translateY(-3px);box-shadow:0 10px 22px rgba(15,110,86,.10)}
.feature-icon{width:38px;height:38px;border-radius:var(--border-radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:18px}
.fi-teal{background:#E1F5EE;color:#0F6E56}
.fi-amber{background:#FAEEDA;color:#BA7517}
.fi-blue{background:#E6F1FB;color:#185FA5}
.fi-coral{background:#FAECE7;color:#993C1D}
.feature-card h3{font-size:15px;font-weight:500;margin-bottom:.4rem}
.feature-card p{font-size:13px;color:var(--color-text-secondary);line-height:1.6}

.how-it-works{background:var(--color-background-primary);border-top:0.5px solid var(--color-border-tertiary);border-bottom:0.5px solid var(--color-border-tertiary);padding:4rem 2rem}
.how-inner{max-width:1000px;margin:0 auto}
.steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem;margin-top:2.5rem}
.step{text-align:center}
.step-num{width:44px;height:44px;border-radius:50%;background:#0F6E56;color:#fff;font-size:16px;font-weight:500;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;box-shadow:0 0 0 6px #E1F5EE}
.step h3{font-size:15px;font-weight:500;margin-bottom:.4rem}
.step p{font-size:13px;color:var(--color-text-secondary);line-height:1.6}

.commands-section{padding:4rem 2rem;max-width:1000px;margin:0 auto}
.commands-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px;margin-top:2rem}
.cmd-card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:1rem 1.25rem;display:flex;align-items:flex-start;gap:12px;transition:transform .15s ease,box-shadow .15s ease}
.cmd-card:hover{transform:translateY(-2px);box-shadow:0 8px 18px rgba(15,110,86,.08)}
.cmd-badge{font-size:11px;padding:3px 8px;border-radius:4px;font-weight:500;white-space:nowrap;flex-shrink:0;margin-top:1px}
.cb-add{background:#E1F5EE;color:#085041}
.cb-sale{background:#FAECE7;color:#993C1D}
.cb-check{background:#E6F1FB;color:#0C447C}
.cb-report{background:#FAEEDA;color:#854F0B}
.cb-buy{background:#EAF3DE;color:#3B6D11}
.cmd-text{font-size:13px;color:var(--color-text-secondary);line-height:1.5}
.cmd-text strong{color:var(--color-text-primary);font-weight:500;display:block;margin-bottom:2px;font-size:14px}

.lang-strip{background:var(--color-background-secondary);border-top:0.5px solid var(--color-border-tertiary);border-bottom:0.5px solid var(--color-border-tertiary);padding:1rem 2rem;text-align:center}
.lang-pills{display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;margin-top:.5rem}
.pill{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:20px;padding:4px 14px;font-size:13px;color:var(--color-text-secondary);transition:border-color .15s ease,transform .15s ease}
.pill:hover{border-color:#0F6E56;transform:translateY(-1px)}

.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin:3rem 0}
.stat-card{background:var(--color-background-secondary);border-radius:var(--border-radius-md);padding:1rem;text-align:center;transition:transform .15s ease}
.stat-card:hover{transform:translateY(-2px)}
.stat-card .num{font-size:28px;font-weight:500;color:#0F6E56}
.stat-card .lbl{font-size:12px;color:var(--color-text-secondary);margin-top:2px}

.cta-section{background:#0F6E56;padding:4rem 2rem;text-align:center;position:relative;overflow:hidden}
.cta-section::before{content:"";position:absolute;top:-70px;right:-60px;width:280px;height:280px;border-radius:50%;background:rgba(255,255,255,.06)}
.cta-section::after{content:"";position:absolute;bottom:-90px;left:-50px;width:260px;height:260px;border-radius:50%;background:rgba(255,255,255,.05)}
.cta-section h2{font-size:30px;font-weight:500;color:#fff;margin-bottom:.75rem;position:relative}
.cta-section p{font-size:15px;color:#9FE1CB;margin-bottom:2rem;position:relative}
.cta-section>div{position:relative}
.btn-white{background:#fff;color:#0F6E56;border:none;padding:12px 28px;font-weight:500}
.btn-white:hover{background:#E1F5EE;transform:translateY(-1px)}
.btn-ghost{background:transparent;border:1px solid rgba(255,255,255,0.4);color:#fff;padding:12px 28px}
.btn-ghost:hover{background:rgba(255,255,255,.08)}

footer{background:var(--color-background-primary);border-top:0.5px solid var(--color-border-tertiary);padding:3rem 2rem 2rem}
.footer-inner{max-width:1000px;margin:0 auto}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:2rem;margin-bottom:2.5rem}
.footer-brand p{font-size:13px;color:var(--color-text-secondary);line-height:1.7;margin-top:.75rem;max-width:220px}
.footer-col h4{font-size:13px;font-weight:500;margin-bottom:.75rem}
.footer-col a{display:block;font-size:13px;color:var(--color-text-secondary);margin-bottom:.4rem;transition:color .15s ease}
.footer-col a:hover{color:var(--color-text-primary)}
.footer-bottom{border-top:0.5px solid var(--color-border-tertiary);padding-top:1.25rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem}
.footer-bottom p{font-size:12px;color:var(--color-text-secondary)}

@media (prefers-reduced-motion: reduce){
  .badge-dot,.rec-dot,.waveform .bar{animation:none}
}
</style>

